# Java backend base URL (server-side only)
BACKEND_JAVA_ENDPOINT=http://localhost:8080

# OpenAI API key for LangChain/LangGraph (server-side only)
OPENAI_API_KEY=sk-...

# LangSmith — observability and LangSmith Studio (server-side only)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=finance-app

# LangGraph server — URL where the agent is running
# Local dev: run `langgraph dev` first (starts on port 2024 by default)
# Production: URL of your LangSmith deployment
LANGGRAPH_API_URL=http://localhost:2024

# Assistant ID — must match the key in langgraph.json "graphs" object
LANGGRAPH_ASSISTANT_ID=financial_agent

# PostgreSQL connection string for LangGraph checkpointer (thread persistence)
# Example: postgresql://user:password@localhost:5432/finanzIA
DATABASE_URI=postgresql://user:password@localhost:5432/finanzIA
